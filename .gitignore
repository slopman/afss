# -----------------------------------------------------------------------------
# Важно: ведущий «/» якорит к корню репо. Без «/» шаблон matчится на любой уровень
# (например «orchestrator» скрывал бы и cmd/orchestrator — ломая docker build).
# -----------------------------------------------------------------------------

# Скачанные CLI и бинарники в корне (не исходники)
/tools/
/bin/

# Собранные бинарники в корне (go build -o …)
/orchestrator
/aggregator
/findings_processor
/normalizer

# Артефакты прогонов у корня репо
/results/
/test/test_results/
/test_normalized/
/debug_results/

# Локальные прогоны / клоны под проект (sec_audit, ручные сканы)
/audits/

# Вложенный репозиторий не для пуша
/rundler/

# Внутренние черновики (остаются локально)
/FINDINGS_PROCESSOR_DESIGN.md
/RESOURCE_MANAGER_DESIGN.md

# Крупные сгенерированные JSON в корне
/all_findings.json
/all_semgrep.json
/combined_findings.json
/normalized_findings.json
/processed_findings.json
/normalized/

# Тяжёлые фикстуры-клоны в test/ (локально)
/test/DTVM/
/test/ops/
/test/safe-config-service/
/test/safe-transaction-service/
/test/safe-wallet-monorepo/

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work
go.work.sum
/vendor/

# IDE / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Логи
*.log
/logs/

# Секреты
.env
.env.*
!.env.example
*.credentials.yaml
*.credentials.yml

# Мусор от редакторов / бэкапы
*.backup
*~
